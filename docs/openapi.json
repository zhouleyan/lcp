  },
  "components": {
    "schemas": {
      "Namespace": {
        "type": "object",
        "properties": {
          "spec": {
            "$ref": "#/components/schemas/NamespaceSpec"
          }
        }
      },
      "NamespaceList": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Namespace"
            }
          },
          "totalCount": {
            "type": "integer",
            "format": "int64"
          }
        }
      },
      "NamespaceMember": {
        "type": "object",
        "properties": {
          "spec": {
            "$ref": "#/components/schemas/NamespaceMemberSpec"
          }
        }
      },
      "NamespaceMemberList": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/NamespaceMember"
            }
          }
        }
      },
      "NamespaceMemberSpec": {
        "type": "object",
        "properties": {
          "role": {
            "type": "string",
            "description": "Role of the member in the namespace",
            "enum": [
              "admin",
              "member",
              "viewer"
            ]
          },
          "userId": {
            "type": "string",
            "description": "ID of the user to add as a member"
          }
        },
        "required": [
          "userId",
          "role"
        ]
      },
      "NamespaceSpec": {
        "type": "object",
        "properties": {
          "description": {
            "type": "string",
            "description": "Description of the namespace"
          },
          "displayName": {
            "type": "string",
            "description": "Display name for the namespace"
          },
          "maxMembers": {
            "type": "integer",
            "format": "int",
            "description": "Maximum number of members allowed"
          },
          "ownerId": {
            "type": "string",
            "description": "ID of the namespace owner"
          },
          "status": {
            "type": "string",
            "description": "Namespace status",
            "enum": [
              "active",
              "inactive"
            ]
          },
          "visibility": {
            "type": "string",
            "description": "Namespace visibility",
            "enum": [
              "public",
              "private"
            ]
          }
        },
        "required": [
          "ownerId"
        ]
      },
      "User": {
        "type": "object",
        "properties": {
          "spec": {
            "$ref": "#/components/schemas/UserSpec"
          }
        }
      },
      "UserList": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/User"
            }
          },
          "totalCount": {
            "type": "integer",
            "format": "int64"
          }
        }
      },
      "UserSpec": {
        "type": "object",
        "properties": {
          "avatarUrl": {
            "type": "string",
            "format": "uri",
            "description": "URL to the user's avatar image"
          },
          "displayName": {
            "type": "string",
            "description": "Display name for the user"
          },
          "email": {
            "type": "string",
            "format": "email",
            "description": "Valid email address"
          },
          "phone": {
            "type": "string",
            "description": "Phone number in E.164 format"
          },
          "status": {
            "type": "string",
            "description": "Account status",
            "enum": [
              "active",
              "inactive"
            ]
          },
          "username": {
            "type": "string",
            "description": "Username must be 3-50 alphanumeric characters or underscores"
          }
        },
        "required": [
          "username",
          "email"
        ]
      }
    }
  }
}
