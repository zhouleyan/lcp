              }
            }
          }
        }
      },
      "patch": {
        "summary": "Patch a Namespace",
        "operationId": "patchNamespace",
        "tags": [
          "Namespace"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
